# Nexus Backend Environment Variables
# Copy this file to .env and fill in your actual values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Database Configuration
# Supabase URL for the hosted database
SUPABASE_URL=https://your-project.supabase.co

# PostgreSQL connection string (from Supabase or self-hosted)
POSTGRES_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600

# OpenRouter Configuration (Agno Framework)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# OpenRouter Model Configuration
# Format: provider/model-name
# The model ID determines which AI model is used for QC data extraction
#
# Supported Models (examples):
# - anthropic/claude-3.5-sonnet (default, recommended for QC tasks)
# - anthropic/claude-3-opus (higher quality, slower)
# - anthropic/claude-3-haiku (faster, lower cost)
# - openai/gpt-4o (OpenAI's latest)
# - openai/gpt-4-turbo (OpenAI multimodal)
# - meta-llama/llama-3.1-70b-instruct (open source)
# - google/gemini-pro (Google's model)
#
# Full list: https://openrouter.ai/models
# Choose based on your requirements for accuracy, speed, and cost
OPENROUTER_MODEL_ID=anthropic/claude-3.5-sonnet

# Claude Configuration
# Maximum tokens for Claude responses
CLAUDE_MAX_TOKENS=4096

# Whisper API Configuration (OpenAI)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
WHISPER_MODEL=whisper-1

# Notes:
# - All API keys are sensitive - never commit the actual .env file to git
# - OPENROUTER_MODEL_ID can be changed to switch AI models without code changes
# - Model validation enforces provider/model-name format (e.g., anthropic/claude-3.5-sonnet)
# - See documentation for model-specific features and pricing
