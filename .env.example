# ==========================================
# PRODUCTION DEPLOYMENT ENVIRONMENT VARIABLES
# ==========================================
# Configure these in Coolify under: Application -> Environment Variables
# Note: Vite requires VITE_ prefix for client-side environment variables
# Only VITE_ prefixed variables are exposed to the browser

# ------------------------------------------
# Clerk Authentication
# ------------------------------------------
# Get from: Clerk Dashboard -> API Keys -> Publishable Key
# Staging: Use your test key (pk_test_...)
# Production: Use your production key (pk_live_...)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx

# ------------------------------------------
# Convex Backend
# ------------------------------------------
# Get from: Convex Dashboard -> Deployments -> Your Deployment -> Deployment URL
# Note: This URL is different for staging vs production deployments
# Format: https://your-deployment-name.convex.cloud (or custom domain)
VITE_CONVEX_DEPLOYMENT_URL=https://xxxxx.convex.cloud

# ------------------------------------------
# OpenAI API (for Whisper voice transcription)
# ------------------------------------------
# Server-side only - NOT exposed to browser
# Get from: OpenAI Dashboard -> API Keys
# Used by Convex backend for transcribing voice input
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# DEPLOYMENT NOTES
# ==========================================
# 1. Always use separate Convex deployments for Staging and Production
# 2. Never share Convex deployments between environments
# 3. Clerk keys must match the environment (test keys for staging, live for production)
# 4. OPENAI_API_KEY is server-side only (used by Convex, not the browser)
